# ============================================================================
# GitHub OAuth App 配置
# ============================================================================
# 1. 打开 https://github.com/settings/developers
# 2. 找到或创建 OAuth App
# 3. 关键信息：
#    - Client ID：填到下方 VITE_GITHUB_CLIENT_ID
#    - Client Secret：只在后端 application.properties 中配置
#      （secret 绝不能出现在前端代码中）
#    - Authorization callback URL：必须与 VITE_GITHUB_REDIRECT_URI 完全一致
#      （GitHub 会严格校验 URL 匹配）
#
# 重要：.env 修改后必须重启前端开发服务器（npm run dev）才能生效！
# ============================================================================

VITE_GITHUB_CLIENT_ID=
VITE_GITHUB_REDIRECT_URI=

# ============================================================================
# 请求超时配置（毫秒）
# ============================================================================
# 默认超时：覆盖认证、文档 CRUD 等常规接口
VITE_API_TIMEOUT_DEFAULT_MS=15000
# AI 接口超时：大模型生成/修复/多轮对话响应较慢，单独配置更长阈值
VITE_API_TIMEOUT_AI_MS=60000
